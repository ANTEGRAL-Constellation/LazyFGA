# lazyFGA self-host 환경변수 예시. 복사: cp .env.example .env

# lazyFGA control-plane API 포트
PORT=8787

# lazyFGA Postgres(의도/정책/감사/토큰/모델 메타) 접속 URL
DATABASE_URL=postgres://lazyfga:lazyfga@localhost:5432/lazyfga

# OpenFGA HTTP 엔드포인트.
# - compose 내부(lazyfga-api 컨테이너)에서는 http://openfga:8080 으로 자동 주입된다.
# - 로컬에서 api를 직접 실행할 때는 compose가 호스트로 매핑한 포트(아래 OPENFGA_HTTP_PORT)와 맞춰야 한다.
OPENFGA_API_URL=http://localhost:8080

# (선택) compose가 OpenFGA를 호스트에 노출할 포트. 호스트에서 8080/3000이 이미 점유 중이면 바꾼다.
# 바꾼 경우 OPENFGA_API_URL의 포트도 같이 맞춰야 한다.
# OPENFGA_HTTP_PORT=8088
# OPENFGA_GRPC_PORT=8081
# OPENFGA_PLAYGROUND_PORT=3003

# (선택) 웹 스튜디오(SPA)를 호스트에 노출할 포트. 기본 5173. nginx가 /api 를 lazyfga-api로 프록시한다.
# WEB_PORT=5173

# (선택) 기존 OpenFGA store에 바인딩. 비우면 부팅 시 store를 새로 생성한다.
LAZYFGA_STORE_ID=

# control-plane admin 토큰(lazyfga-10에서 사용). compose는 이 값이 없으면 기동을 거부한다
# (LFGA-22 §4.4-4: 알려진 자리표시자를 암묵적으로 배포하지 않도록 명시 설정 요구). 운영 시 반드시 강한 값으로 교체.
ADMIN_TOKEN=
