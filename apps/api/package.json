{
  "name": "@lazyfga/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@lazyfga/compiler": "workspace:*",
    "@lazyfga/shared": "workspace:*",
    "@openfga/sdk": "^0.9.6",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
