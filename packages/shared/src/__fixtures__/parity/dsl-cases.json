      "dsl": "model\n  schema 1.1\ntype user\ntype doc\n  relations\n    define viewer: [user with nested]\n    define can_read: viewer\ncondition nested(tier: string, n: int) {\n  tier == \"gold\" || (n > 2 && n < 10)\n}"
