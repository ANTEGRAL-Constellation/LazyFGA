    {
      "name": "all-types-condition",
      "ir": {
        "schemaVersion": "1.1",
        "groups": [],
        "resources": [
          {
            "name": "doc",
            "parents": [],
            "roles": [
              {
                "name": "viewer",
                "assignableBy": [
                  {
                    "kind": "user",
                    "condition": "gate"
                  }
                ]
              }
            ],
            "permissions": [
              {
                "name": "read",
                "grantedByRoles": ["viewer"],
                "inheritFromParents": []
              }
            ]
          }
        ],
        "conditions": [
          {
            "name": "gate",
            "params": [
              {
                "name": "current_time",
                "type": "timestamp"
              },
              {
                "name": "user_ip",
                "type": "ipaddress"
              },
              {
                "name": "tier",
                "type": "string"
              },
              {
                "name": "level",
                "type": "int"
              },
              {
                "name": "score",
                "type": "double"
              },
              {
                "name": "flag",
                "type": "bool"
              }
            ],
            "tree": {
              "op": "and",
              "children": [
                {
                  "kind": "time",
                  "param": "current_time",
                  "op": "lt",
                  "rhs": {
                    "kind": "literal",
                    "rfc3339": "2030-01-01T00:00:00Z"
                  }
                },
                {
                  "kind": "ip",
                  "param": "user_ip",
                  "op": "in_cidr",
                  "cidr": "10.0.0.0/8"
                },
                {
                  "kind": "value",
                  "param": "tier",
                  "op": "eq",
                  "value": "gold"
                },
                {
                  "kind": "value",
                  "param": "level",
                  "op": "gte",
                  "value": 3
                },
                {
                  "kind": "value",
                  "param": "score",
                  "op": "gt",
                  "value": 1.5
                },
                {
                  "kind": "value",
                  "param": "flag",
                  "op": "eq",
                  "value": true
                }
              ]
            }
          }
        ]
      },
      "dsl": "model\n  schema 1.1\ntype user\ntype doc\n  relations\n    define viewer: [user with gate]\n    define can_read: viewer\ncondition gate(current_time: timestamp, user_ip: ipaddress, tier: string, level: int, score: double, flag: bool) {\n  current_time < timestamp(\"2030-01-01T00:00:00Z\") && user_ip.in_cidr(\"10.0.0.0/8\") && tier == \"gold\" && level >= 3 && score > 1.5 && flag == true\n}"
    },
